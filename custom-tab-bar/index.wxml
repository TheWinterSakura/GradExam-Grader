<view class="tab-bar">
  <view 
    wx:for="{{list}}" 
    wx:key="index" 
    class="tab-bar-item" 
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <image 
      class="tab-icon {{selected === index ? 'active' : ''}}"
      src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
      mode="aspectFit"
    ></image>
    <text 
      class="tab-text {{selected === index ? 'active' : ''}}"
      style="color: {{selected === index ? selectedColor : color}}"
    >
      {{item.text}}
    </text>
  </view>
</view>
